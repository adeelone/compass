# App
ENVIRONMENT=development
APP_ENCRYPTION_KEY=change-me-32-byte-development-key

# Backend
DATABASE_URL=postgresql+psycopg://compass:compass@postgres:5432/compass
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=compass-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Feature flags
ENABLE_LLM_FEATURES=false
ENABLE_EMAIL_INGEST=false
ENABLE_HEADLESS_WORKERS=false
ENABLE_PUBLIC_PROFILES=false
ENABLE_PUSH=false

# Providers
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
OPENAI_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_EMAIL=
USAJOBS_API_KEY=
RESEND_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_USE_MOCK_API=false

